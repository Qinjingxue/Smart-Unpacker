        ]
      },
      {
        "name": "whitelist",
        "enabled": false,
        "path_globs": [
          "archives/**",
          "downloads/**"
        ],
        "prune_dir_globs": [
          "archives",
          "downloads"
        ],
        "allowed_files": [
          "sample.zip"
        ],
        "allowed_extensions": [
          ".zip",
          ".7z",
          ".rar"
        ]
      },
      {
        "name": "blacklist",
        "enabled": true,
        "path_globs": [
          ".git/**",
          ".vscode/**",
          "$RECYCLE.BIN/**"
        ],
        "prune_dir_globs": [
          ".git",
          ".vscode",
          "__pycache__",
          "node_modules",
          "site-packages",
          ".venv",
          "venv",
          "env",
          ".cache",
          "repositories"
        ],
        "blocked_files": [
          "Thumbs.db",
          "desktop.ini"
        ],
        "blocked_extensions": [
          ".dll",
          ".save",
          ".py",
          ".pyc",
          ".json",
          ".xml",
          ".cfg",
          ".ini",
          ".sys",
          ".db",
          ".msi",
          ".cur",
          ".ani",
          ".ttf",
          ".woff",
          ".ico",
          ".pak",
          ".obb",
          ".unitypackage",
          ".jar",
          ".apk",
          ".ipa",
          ".epub",
          ".odt",
          ".ods",
          ".odp",
          ".docx",
          ".xlsx",
          ".pptx",
          ".whl",
          ".xpi",
          ".war",
          ".ear",
          ".aab",
          ".ckpt",
          ".pt",
          ".pth",
          ".safetensors",
          ".bin",
          ".dat",
          ".docm",
          ".xlsm",
          ".pptm"
        ]
      },
      {
        "name": "size_range",
        "enabled": true,
        "range": "r >= 1 MB"
      },
      {
        "name": "mtime_range",
        "enabled": false,
        "date": "20270101 00:00 > d >= 20240101 00:00"
      }
    ]
  },
  "performance": {
    "scheduler_profile": "auto",
    "max_extract_task_seconds": 1800,
    "process_no_progress_timeout_seconds": 180,
    "process_sample_interval_ms": 500,
    "persistent_workers": true,
    "profile_calibration_window_size": 4,
    "profile_regression_ratio": 0.8,
    "profile_improvement_ratio": 1.2,
    "profile_calibration_max_delta": 1,
    "profile_calibration_min_parallel": 2,
    "profile_calibration_cache_enabled": true,
    "resource_guard": {
      "enabled": false,
      "max_file_count": 0,
      "max_total_unpacked_size": 0,
      "max_largest_item_size": 0,
      "max_compression_ratio": 0
    }
  },
  "watch": {
    "interval_seconds": 5.0,
    "stable_seconds": 10.0,
    "recursive": true,
    "initial_scan": true,
    "max_folders": 16,
    "observer_stop_timeout_seconds": 5.0
  },
  "extraction": {
    "write_progress_manifest": false
  },
  "analysis": {
    "enabled": true,
    "task_parallel": true,
    "task_max_workers": 4,
    "cache_size": 512,
    "parallel": true,
    "max_workers": 3,
    "max_concurrent_reads": 1,
    "shared_cache_mb": 64,
    "max_read_mb_per_archive": 256,
    "prepass": {
      "enabled": true,
      "head_bytes": 1048576,
      "tail_bytes": 1048576
    },
    "fuzzy": {
      "enabled": true,
      "modules": [
        {
          "name": "binary_profile",
          "enabled": true,
          "window_bytes": 65536,
          "max_windows": 8,
          "max_sample_bytes": 1048576,
          "entropy_high_threshold": 6.8,
          "entropy_low_threshold": 3.5,
          "entropy_jump_threshold": 1.25,
          "ngram_top_k": 8,
          "max_ngram_sample_bytes": 262144
        }
      ]
    },
    "thresholds": {
      "extractable_confidence": 0.85,
      "repair_confidence": 0.35
    },
    "modules": [
      {
        "name": "zip",
        "enabled": true,
        "max_cd_entries_to_walk": 64
      },
      {
        "name": "rar",
        "enabled": true,
        "max_blocks_to_walk": 4096
      },
      {
        "name": "seven_zip",
        "enabled": true,
        "max_next_header_check_bytes": 1048576
      },
      {
        "name": "tar",
        "enabled": true,
        "max_entries_to_walk": 64
      },
      {
        "name": "gzip",
        "enabled": true,
        "max_probe_bytes": 4194304
      },
      {
        "name": "bzip2",
        "enabled": true,
        "max_probe_bytes": 4194304
      },
      {
        "name": "xz",
        "enabled": true,
        "max_probe_bytes": 4194304
      },
      {
        "name": "zstd",
        "enabled": true,
        "max_probe_bytes": 4194304
      },
      {
        "name": "tar_gz",
        "enabled": true,
        "max_probe_bytes": 4194304
      },
      {
        "name": "tar_bz2",
        "enabled": true,
        "max_probe_bytes": 4194304
      },
      {
        "name": "tar_xz",
        "enabled": true,
        "max_probe_bytes": 4194304
      },
      {
        "name": "tar_zst",
        "enabled": true,
        "max_probe_bytes": 4194304
      }
    ]
  },
  "verification": {
    "enabled": true,
    "max_retries": 2,
    "cleanup_failed_output": true,
    "accept_partial_when_source_damaged": true,
    "partial_min_completeness": 0.2,
    "complete_accept_threshold": 0.999,
    "partial_accept_threshold": 0.2,
    "retry_on_verification_failure": true,
    "methods": [
      {
        "name": "extraction_exit_signal",
        "enabled": true
      },
      {
        "name": "output_presence",
        "enabled": true
      },
      {
        "name": "expected_name_presence",
        "enabled": true,
        "max_expected_names": 50
      },
      {
        "name": "manifest_size_match",
        "enabled": true,
        "max_expected_names": 2000
      },
      {
        "name": "archive_test_crc",
        "enabled": true,
        "max_items": 200000,
        "max_reported_items": 20
      },
      {
        "name": "sample_readability",
        "enabled": true,
        "max_samples": 64,
        "read_bytes": 4096,
        "max_reported_items": 20
      }
    ]
  },
  "repair": {
    "enabled": true,
    "workspace": ".sunpack_repair",
    "keep_candidates": false,
    "max_modules_per_job": 4,
    "max_attempts_per_task": 1,
    "max_repair_rounds_per_task": 3,
    "max_repair_seconds_per_task": 120,
    "max_repair_generated_files_per_task": 16,
    "max_repair_generated_mb_per_task": 2048,
    "stages": {
      "targeted": true,
      "safe_repair": true,
      "deep": false
    },
    "safety": {
      "allow_unsafe": false,
      "allow_partial": true,
      "allow_lossy": false
    },
    "deep": {
      "max_candidates_per_module": 3,
      "max_entries": 20000,
      "max_seconds_per_module": 30,
      "max_input_size_mb": 512,
      "max_output_size_mb": 2048,
      "max_entry_uncompressed_mb": 512,
      "verify_candidates": true
    },
    "auto_deep": {
      "enabled": true,
      "require_verification_repair": true,
      "max_modules": 2,
      "max_candidates_per_module": 1,
      "max_input_size_mb": 128
    },
    "beam": {
      "enabled": true,
      "beam_width": 4,
      "max_candidates_per_state": 4,
      "max_analyze_candidates": 8,
      "max_assess_candidates": 4,
      "max_rounds": 3,
      "min_improvement": 0.01
    },
    "modules": [
      {
        "name": "zip_eocd_repair",
