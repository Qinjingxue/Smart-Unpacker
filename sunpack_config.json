{
  "cli": {
    "language": "zh"
  },
  "thresholds": {
    "archive_score_threshold": 6,
    "maybe_archive_threshold": 3
  },
  "recursive_extract": "*",
  "post_extract": {
    "archive_cleanup_mode": "r",
    "flatten_single_directory": true
  },
  "filesystem": {
    "directory_scan_mode": "*",
    "scan_filters_enabled": true,
    "scan_filters": [
      {
        "name": "scene_semantics",
        "enabled": true,
        "protect_runtime_resources": true,
        "prune_dir_globs": [
          ".git", ".vscode", "__pycache__", "node_modules", "site-packages", ".venv", "venv", "env", ".cache",
          "repositories"
        ],
        "path_globs": [".git/**", ".vscode/**", "$RECYCLE.BIN/**"]
      },
      {
        "name": "whitelist",
        "enabled": false,
        "path_globs": ["archives/**", "downloads/**"],
        "prune_dir_globs": ["archives", "downloads"],
        "allowed_files": ["sample.zip"],
        "allowed_extensions": [".zip", ".7z", ".rar"]
      },
      {
        "name": "blacklist",
        "enabled": true,
        "blocked_files": ["Thumbs.db", "desktop.ini"],
        "blocked_extensions": [
          ".dll", ".save", ".py", ".pyc", ".json", ".xml", ".cfg", ".ini", ".sys", ".db", ".msi", ".cur",
          ".ani", ".ttf", ".woff", ".ico", ".pak", ".obb", ".unitypackage", ".jar", ".apk", ".ipa", ".epub",
          ".odt", ".ods", ".odp", ".docx", ".xlsx", ".pptx", ".whl", ".xpi", ".war", ".ear", ".aab", ".ckpt",
          ".pt", ".pth", ".safetensors", ".bin", ".dat", ".docm", ".xlsm", ".pptm"
        ]
      },
      {
        "name": "size_range",
        "enabled": true,
        "range": "r >= 1 MB"
      },
      {
        "name": "mtime_range",
        "enabled": false,
        "date": "20270101 00:00 > d >= 20240101 00:00"
      }
    ]
  },
  "performance": {
    "scheduler_profile": "auto"
  },
  "repair": {
    "telemetry": {
      "enabled": false
    }
  },
  "detection": {
    "rule_pipeline": {
      "scoring": [
        {
          "name": "embedded_payload_identity",
          "embedded_payload_scan_level": "deep"
        }
      ]
    }
  }
}
